# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Env
.env
.env.local

# Runtime state (regenerated each session; keep audit trail in git only when intended)
# Note: state/ contents are intentionally committed by CI workflows; ignore only local-only files
state/local/
*.tmp

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Local OHLCV cache — grows to ~50 MB over a year, regenerates on demand
# via tools.history fall-through to yfinance. State is mutable and not
# worth committing; the bot works without it (just slower for the first
# few runs while it warms up).
state/ohlcv.db
state/ohlcv.db-*
