# Copy to .env for local dev. In GitHub Actions, set these as repository secrets.

# Email notifications (Brevo free tier — 300/day, single-sender verification, no domain needed)
# Sign up at https://brevo.com, verify the sender address (NOTIFY_EMAIL_FROM) under
# Senders & IP → Senders, then get an API key from Account → SMTP & API.
BREVO_API_KEY=
NOTIFY_EMAIL_TO=dariozela1@gmail.com
NOTIFY_EMAIL_FROM=dariozela1@gmail.com

# Wave 2 — Alpaca paper trading. One pair per slot. Strategy configs reference
# slots by number; at least slot 1 must be set for Wave 2a (momentum-trader).
ALPACA_API_KEY__1=
ALPACA_API_SECRET__1=
# ALPACA_API_KEY__2=
# ALPACA_API_SECRET__2=
# ALPACA_API_KEY__3=
# ALPACA_API_SECRET__3=

# Wave 2b — Claude Code Max plan OAuth token (used by LLM-driven strategies).
# Generate locally with `claude setup-token` then store as a GitHub Actions secret.
CLAUDE_CODE_OAUTH_TOKEN=
